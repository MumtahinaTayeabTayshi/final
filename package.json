{
  "name": "booknest-mern",
  "version": "1.0.0",
  "private": true,
  "description": "BookNest is a full MERN reading tracker and library management application.",
  "type": "module",
  "scripts": {
    "client": "vite",
    "server": "node backend/server.js",
    "dev:server": "nodemon backend/server.js",
    "dev": "concurrently \"npm run client\" \"npm run dev:server\"",
    "build": "vite build",
    "preview": "vite preview",
    "seed": "node backend/seeds/books.js"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "axios": "^1.7.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "mongoose": "^8.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "nodemon": "^3.1.7",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
